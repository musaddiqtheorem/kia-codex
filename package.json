{
  "name": "kia-codex",
  "version": "0.1.0",
  "private": true,
  "description": "Email Analytics Platform scaffold",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch src/server.ts",
    "dev:web": "npm --prefix client run dev",
    "build": "npm run build:api && npm run build:web",
    "build:api": "tsc -p tsconfig.json",
    "build:web": "npm --prefix client run build",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx scripts/migrate.ts",
    "seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "duckdb": "^1.1.3",
    "express": "^4.19.2",
    "zod": "^3.23.8",
    "bullmq": "^5.8.0",
    "ioredis": "^5.4.1",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "@types/multer": "^1.4.12"
  }
}
